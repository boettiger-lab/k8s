# This is all public information, copied from https://nrp.ai/config
# Sync to https://nrp.ai/config
# this file merely adds additional optional args for headless auth.
apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: 
    server: https://67.58.53.148:443
  name: nautilus
contexts:
- context:
    cluster: nautilus
    user: oidc
  name: nautilus
current-context: nautilus
users:
- name: oidc
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      command: kubectl
      args:
      - oidc-login
      - get-token
      - --token-cache-storage=keyring
      - --oidc-issuer-url=https://authentik.nrp-nautilus.io/application/o/k8s/
      - --oidc-client-id=xrxBIaWxeRmGJUwSvaLjUzMEFZzQu2b4nk9I0B2W
      - --listen-address=0.0.0.0:8000
      - --oidc-extra-scope=profile,offline_access
      - --grant-type=device-code
      - --skip-open-browser
      - --token-cache-storage=disk
